<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace = "com.ssli.springbootdemo.mapper.BookMapper">
    <select id = "selectById" resultType="com.ssli.springbootdemo.entity.Book">
        select * from book where id = #{id}
    </select>

    <select id="selectByName" resultType="com.ssli.springbootdemo.entity.Book">
        select id, name, price
        from book
        where name = #{name}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into book(name, price)
        values (#{name}, #{price})
    </insert>

    <delete id="deleteById">
        delete
        from book
        where id = #{id}
    </delete>

    <update id="updateById">
        update book
        set name = #{name},
        price = #{price}
        where id = #{id}
    </update>

    <select id="selectList" resultType="com.ssli.springbootdemo.entity.Book">
        select id, name, price
        from book
        <where>
            <if test="name != null and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="minPrice != null">
                and price <![CDATA[ >= ]]> #{minPrice}
            </if>
            <if test="maxPrice != null">
                and price <![CDATA[ <= ]]> #{maxPrice}
            </if>
        </where>
        order by id desc
        <if test="offset != null and pageSize != null">
            limit #{offset}, #{pageSize}
        </if>
    </select>
</mapper>

